<Project Sdk="Microsoft.NET.Sdk">

  <!-- Alternative to build.cmd for Visual Studio or `dotnet build`. -->
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net48</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <RootNamespace>PulseClock</RootNamespace>
    <AssemblyName>PulseClock</AssemblyName>
    <StartupObject>PulseClock.Program</StartupObject>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>disable</Nullable>
  </PropertyGroup>

</Project>
